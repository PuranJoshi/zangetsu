# Code Council configuration
# Copy this file to ~/.code-council/env and fill in your API key.
#
#   mkdir -p ~/.code-council
#   cp env.example ~/.code-council/env
#
# Existing environment variables take precedence over this file.

# ---------------------------------------------------------------------------
# Required: LLM provider credentials
# ---------------------------------------------------------------------------
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.langdock.com/openai/eu/v1

# ---------------------------------------------------------------------------
# Models
#
# All skills default to CODE_COUNCIL_MODEL. Every skill below is set to
# gpt-5.4-mini for low cost. Change any line to a stronger model when needed.
#
# Resolution order: env var > skill frontmatter > CODE_COUNCIL_MODEL
#
# NOTE: The model names below are for Langdock (api.langdock.com). If you
# use a different provider, replace them with valid model IDs for your
# endpoint. You can list available models by querying:
#   curl -H "Authorization: Bearer $LLM_API_KEY" $LLM_BASE_URL/models
# ---------------------------------------------------------------------------

CODE_COUNCIL_MODEL=gpt-5.4-mini

# -- Framer (1 call + possible clarification rounds) --
CODE_COUNCIL_MODEL_FRAMER=gpt-5.4-mini

# -- Advisors (run in parallel, 6 calls per plan) --
CODE_COUNCIL_MODEL_EXECUTOR=gpt-5.4-mini
CODE_COUNCIL_MODEL_SECURITY=gpt-5.4-mini
CODE_COUNCIL_MODEL_QUALITY=gpt-5.4-mini
CODE_COUNCIL_MODEL_BUSINESS=gpt-5.4-mini
CODE_COUNCIL_MODEL_ARCHITECT=gpt-5.4-mini
CODE_COUNCIL_MODEL_RISK=gpt-5.4-mini

# -- Synthesis (2 calls: conflict analysis + plan generation) --
CODE_COUNCIL_MODEL_SYNTHESIZER_ANALYSIS=gpt-5.4-mini
CODE_COUNCIL_MODEL_SYNTHESIZER=gpt-5.4-mini

# -- Council review (1 call for decision gate) --
CODE_COUNCIL_MODEL_DECISION_GATE=gpt-5.4-mini

# -- Export humaniser (1 call when using --export) --
CODE_COUNCIL_MODEL_HUMANIZER=gpt-5.4-mini

# ---------------------------------------------------------------------------
# Other settings (optional)
# ---------------------------------------------------------------------------
# CODE_COUNCIL_AGENT_TIMEOUT_SECONDS=120
# CODE_COUNCIL_ADVISOR_TEMPERATURE_SPREAD=0.4
# CODE_COUNCIL_MAX_NEGOTIATION_ROUNDS=3
# CODE_COUNCIL_SAVE_PLANS=True
# CODE_COUNCIL_PLAN_DIR=~/.code-council/plans
# CODE_COUNCIL_TRANSCRIPT_DIR=~/.code-council/transcripts

# -- Prompt caching (reduces token costs by caching shared content) --
# CODE_COUNCIL_PROMPT_CACHING=True
# CODE_COUNCIL_PROVIDER_TYPE=auto    # auto | anthropic | openai | none
